rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lock down by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Isolate social streams per user
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // OmniPost Aggregation Stream: Strictly private to the user
      match /omni_feed/{postId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // Writes are handled exclusively via Cloud Functions backend
        allow write: if false; 
      }
    }
    
    // Platform Cache: Shared cache for platform rate-limit protection
    match /platform_cache/{platform} {
      allow read: if request.auth != null; // Registered users can read cache
      allow write: if false; // Only backend can write
    }
  }
}
