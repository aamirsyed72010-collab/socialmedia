{
  "apphosting": {
    "source": "apps/web",
    "region": "us-central1"
  },
  "firestore": {
    "rules": "apps/firebase-backend/database/firestore.rules",
    "indexes": "apps/firebase-backend/database/firestore.indexes.json"
  },
  "functions": [
    {
      "source": "apps/firebase-backend",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npx nx build firebase-backend"
      ]
    }
  ],
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "ui": { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}
